APP_NAME=STEM Reasoning Lab
ENVIRONMENT=development
BACKEND_CORS_ORIGINS=http://localhost:3001,http://127.0.0.1:3001

# inference: Hugging Face Inference Providers. local: transformers.pipeline.
HF_EXECUTION_MODE=inference
HF_TOKEN=
HF_MODEL_ID=Qwen/Qwen2.5-7B-Instruct
HF_INFERENCE_PROVIDER=auto
HF_MAX_NEW_TOKENS=1400
HF_TEMPERATURE=0.35
HF_TIMEOUT_SECONDS=120
SELF_CONSISTENCY_SAMPLES=5

DATABASE_URL=sqlite:///./stemlab.db
SECRET_KEY=replace-with-a-random-secret
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=14
COOKIE_SECURE=false
